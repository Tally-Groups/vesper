DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# Shared secret used for metering HMAC verification from client to server.
METERING_HMAC_SECRET="replace-with-strong-random-secret"

# Secret used by cron jobs and internal repair endpoints.
METERING_CRON_SECRET="replace-with-strong-random-secret"

# Vercel Queue topic name for metering events.
METERING_QUEUE_NAME="metering-events"

# Vercel Queues SDK may require additional environment variables in local dev.
# Run `vercel link` and `vercel env pull` to populate them.

